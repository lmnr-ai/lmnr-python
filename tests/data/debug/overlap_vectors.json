{
  "description": "Cross-language parity vectors for the §F overlap guard (has_overlap / hasOverlap). Each case provides spine calls (by start/end) and the window size n. 'expect' is true when any of the first n calls overlap in [start, end).",
  "cases": [
    {
      "name": "sequential-no-overlap",
      "spine_calls": [
        { "start_time": 0.0, "end_time": 1.0 },
        { "start_time": 1.0, "end_time": 2.0 },
        { "start_time": 2.0, "end_time": 3.0 }
      ],
      "n": 3,
      "expect": false
    },
    {
      "name": "overlapping-pair",
      "spine_calls": [
        { "start_time": 0.0, "end_time": 1.5 },
        { "start_time": 1.0, "end_time": 2.0 }
      ],
      "n": 2,
      "expect": true
    },
    {
      "name": "overlap-outside-window-ignored",
      "spine_calls": [
        { "start_time": 0.0, "end_time": 1.0 },
        { "start_time": 1.0, "end_time": 2.0 },
        { "start_time": 1.5, "end_time": 3.0 }
      ],
      "n": 2,
      "expect": false
    },
    {
      "name": "overlap-inside-window-detected",
      "spine_calls": [
        { "start_time": 0.0, "end_time": 1.0 },
        { "start_time": 1.0, "end_time": 2.5 },
        { "start_time": 2.0, "end_time": 3.0 }
      ],
      "n": 3,
      "expect": true
    },
    {
      "name": "unsorted-input-still-detected",
      "spine_calls": [
        { "start_time": 2.0, "end_time": 3.0 },
        { "start_time": 0.0, "end_time": 2.5 }
      ],
      "n": 2,
      "expect": true
    }
  ]
}
